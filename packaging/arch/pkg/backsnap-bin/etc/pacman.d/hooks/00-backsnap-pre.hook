# backsnap — automatischer Snapper-Snapshot vor jedem Pacman-Update
[Trigger]
Operation = Upgrade
Operation = Install
Operation = Remove
Type = Package
Target = *

[Action]
Description = backsnap: Pre-Update Snapshot (falls nötig)...
When = PreTransaction
Exec = /usr/lib/backsnap/backsnap-pacman-pre
Depends = pacman
